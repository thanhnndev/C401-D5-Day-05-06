# PostgreSQL (LangGraph PostgresSaver / psycopg)
# Example: postgresql://user:password@localhost:5432/dbname
DATABASE_URL=

# Google AI Studio (Gemini) — https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Optional; default in code is gemini-2.5-flash if unset (langchain-google-genai / Gemini API)
# GEMINI_MODEL=gemini-2.5-flash

# SMTP (tools.send_email) — mail.thanhnn.dev: use starttls + 587 or ssl + 465 per server
SMTP_TLS_MODE=starttls
SMTP_HOST=mail.thanhnn.dev
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
